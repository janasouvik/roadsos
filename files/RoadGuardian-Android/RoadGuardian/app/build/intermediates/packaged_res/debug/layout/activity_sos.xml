<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A0000">

    <!-- Dark Red background overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_sos_screen"/>

    <!-- SOS Header -->
    <TextView
        android:id="@+id/sosTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🚨 SOS ACTIVATED"
        android:textColor="@color/white"
        android:textSize="24sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:layout_marginTop="60dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Big SOS Button -->
    <FrameLayout
        android:id="@+id/sosBigBtn"
        android:layout_width="200dp"
        android:layout_height="200dp"
        app:layout_constraintTop_toBottomOf="@id/sosTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="40dp">

        <View android:layout_width="200dp" android:layout_height="200dp"
            android:background="@drawable/bg_sos_ring_3" android:alpha="0.3"/>
        <View android:layout_width="160dp" android:layout_height="160dp"
            android:layout_gravity="center" android:background="@drawable/bg_sos_ring_2" android:alpha="0.5"/>
        <View android:layout_width="120dp" android:layout_height="120dp"
            android:layout_gravity="center" android:background="@drawable/bg_sos_ring_1"/>

        <LinearLayout android:layout_width="120dp" android:layout_height="120dp"
            android:layout_gravity="center" android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="SOS" android:textColor="@color/white" android:textSize="32sp"
                android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="TAP TO CALL" android:textColor="@color/white_80" android:textSize="11sp"
                android:letterSpacing="0.1"/>
        </LinearLayout>
    </FrameLayout>

    <!-- Status Text -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🚨 Sending emergency alert to authorities..."
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/sosBigBtn"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Location Status -->
    <TextView
        android:id="@+id/locationStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📍 Sharing your live location with emergency services"
        android:textColor="@color/primary_light"
        android:textSize="13sp"
        android:gravity="center"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/statusText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Countdown -->
    <TextView
        android:id="@+id/countdownText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Alerting in 10 seconds..."
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/locationStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Call Now Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/callNowBtn"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="📞 Call 112 NOW"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="16dp"
        app:backgroundTint="@color/primary"
        app:cornerRadius="14dp"
        app:layout_constraintBottom_toTopOf="@id/cancelSosBtn"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Cancel Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/cancelSosBtn"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Cancel SOS"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="40dp"
        style="@style/Btn.Ghost"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
