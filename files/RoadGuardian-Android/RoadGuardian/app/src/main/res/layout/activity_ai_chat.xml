<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/surface"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="48dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/backBtn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_back"
            android:tint="@color/white"
            android:padding="8dp"/>

        <!-- AI Avatar -->
        <FrameLayout
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp">
            <View android:layout_width="40dp" android:layout_height="40dp"
                android:background="@drawable/bg_ai_avatar"/>
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:layout_gravity="center" android:src="@drawable/ic_ai"
                android:tint="@color/white"/>
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Road Guardian AI"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <View android:layout_width="7dp" android:layout_height="7dp"
                    android:background="@drawable/bg_dot_green"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="  Online • Gemini AI" android:textColor="@color/success"
                    android:textSize="12sp"/>
            </LinearLayout>
        </LinearLayout>

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_phone"
            android:tint="@color/primary"
            android:padding="8dp"/>
    </LinearLayout>

    <!-- Quick Help Chips -->
    <HorizontalScrollView
        android:id="@+id/quickHelpScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        app:layout_constraintTop_toBottomOf="@id/header">

        <LinearLayout
            android:id="@+id/quickHelpContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🚨 Accident First Aid"
                android:textColor="@color/text_primary"
                android:layout_marginEnd="8dp"
                app:chipBackgroundColor="@color/surface_variant"
                app:chipStrokeColor="@color/divider"
                app:chipStrokeWidth="1dp"/>

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔥 Car Fire Escape"
                android:textColor="@color/text_primary"
                android:layout_marginEnd="8dp"
                app:chipBackgroundColor="@color/surface_variant"
                app:chipStrokeColor="@color/divider"
                app:chipStrokeWidth="1dp"/>

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏥 Nearest Hospital"
                android:textColor="@color/text_primary"
                android:layout_marginEnd="8dp"
                app:chipBackgroundColor="@color/surface_variant"
                app:chipStrokeColor="@color/divider"
                app:chipStrokeWidth="1dp"/>

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🚔 Call Police"
                android:textColor="@color/text_primary"
                android:layout_marginEnd="8dp"
                app:chipBackgroundColor="@color/surface_variant"
                app:chipStrokeColor="@color/divider"
                app:chipStrokeWidth="1dp"/>
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Chat RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chatRecycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/quickHelpScroll"
        app:layout_constraintBottom_toTopOf="@id/inputContainer"/>

    <!-- Typing Indicator -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/typingIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="8dp"
        app:cardBackgroundColor="@color/surface"
        app:cardCornerRadius="12dp"
        app:layout_constraintBottom_toTopOf="@id/inputContainer"
        app:layout_constraintStart_toStartOf="parent">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI is thinking..."
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:padding="10dp"/>
    </com.google.android.material.card.MaterialCardView>

    <!-- Input Container -->
    <LinearLayout
        android:id="@+id/inputContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/surface"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            style="@style/Input.Default"
            android:hint="Ask for emergency guidance...">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/messageInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:maxLines="4"
                android:inputType="textMultiLine"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/sendBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:src="@drawable/ic_send"
            app:backgroundTint="@color/primary"
            app:fabSize="mini"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
